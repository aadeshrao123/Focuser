{
  "manifest_version": 3,
  "name": "Focuser",
  "version": "0.1.0",
  "description": "Website blocker — blocks distracting sites to help you stay focused",
  "permissions": [
    "activeTab",
    "tabs",
    "webRequest",
    "webNavigation",
    "scripting",
    "storage",
    "nativeMessaging"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "focuser@focuser-app",
      "strict_min_version": "109.0"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-early.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "blocked.css", "content-block.js", "content-hide.css", "content-early.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
