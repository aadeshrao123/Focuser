{
  "productName": "Focuser",
  "version": "0.1.0",
  "identifier": "com.focuser.app",
  "build": {
    "frontendDist": "./ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Focuser",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src * 'unsafe-inline' 'unsafe-eval' data: blob:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "externalBin": [
      "binaries/focuser-service",
      "binaries/focuser-cli",
      "binaries/focuser-native"
    ],
    "resources": [],
    "copyright": "Copyright 2026 Focuser Contributors",
    "shortDescription": "Website and application blocker",
    "longDescription": "Focuser is a free, open-source website and application blocker that helps you stay focused by blocking distracting websites and apps.",
    "windows": {
      "nsis": {
        "installMode": "both",
        "startMenuFolder": "Focuser",
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null,
        "installerHooks": "nsis/installer-hooks.nsi"
      },
      "wix": null
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libappindicator3-1"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {}
}
